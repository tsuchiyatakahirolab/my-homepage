# ─────────────────────────────────────────────────────────────
# Notion API Integration for Latest News
# ─────────────────────────────────────────────────────────────

# Required: Internal integration token
# 取得場所: https://www.notion.so/profile/integrations → 「新しいインテグレーション」
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required (preferred): Data Source ID
# Notion SDK v5 では data source ID を使います。
# 取得方法: Notion でデータベースを開き、URL の末尾から ID をコピー
#   例: https://www.notion.so/<workspace>/<DATA_SOURCE_ID>?v=...
NOTION_DATA_SOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Alternative: Database ID (互換性のため)
# NOTION_DATA_SOURCE_ID が未設定の場合、こちらが使われます。
# 多くの場合、database ID と data source ID は同一です。
# NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optional: Webhook verification token (on-demand revalidation 用)
# Notion webhook subscription 登録時に受け取る verification_token を設定します。
# POST /api/revalidate に送信されるリクエストの X-Notion-Signature ヘッダーを
# この token で HMAC-SHA256 検証します。
# NOTION_WEBHOOK_SECRET=your-verification-token-here
